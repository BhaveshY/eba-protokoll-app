{
  "name": "eba-protokoll",
  "version": "0.1.2",
  "description": "Meetings aufnehmen, transkribieren und protokollieren (Deepgram + Cowork).",
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "author": "EB&A",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "node scripts/dev-electron.mjs",
    "dev": "node scripts/dev.mjs",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json && node scripts/mark-cjs.mjs",
    "build": "npm run build:renderer && npm run build:electron",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "typecheck": "tsc --noEmit && tsc --noEmit -p electron/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "electron-store": "^10.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-electron": "^0.29.0",
    "vitest": "^2.1.8"
  }
}
